generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  stores       Store[]
  shifts       Shift[]
  subscription Subscription?
}

model Store {
  id           String        @id @default(uuid())
  name         String
  type         String
  userId       String
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id])
  products     Product[]
  shifts       Shift[]
  transactions Transaction[]
  promos       Promo[]
}

model Product {
  id               String            @id @default(uuid())
  name             String
  barcode          String?
  sku              String?
  price            Int
  costPrice        Int?
  stock            Int               @default(0)
  minStock         Int               @default(5)
  unit             String            @default("pcs")
  category         String?
  imageUrl         String?
  label            String?
  storeId          String
  store            Store             @relation(fields: [storeId], references: [id])
  transactionItems TransactionItem[]
  promoRules       PromoRule[]       // ← ganti dari promos Promo[] ke PromoRule[]
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  productId     String
  qty           Int
  price         Int
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique
  plan      String
  startDate DateTime
  expiredAt DateTime
  status    String
  user      User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id             String            @id @default(uuid())
  storeId        String
  total          Int
  discountAmount Int               @default(0)
  paymentMethod  String            @default("cash")
  createdAt      DateTime          @default(now())
  store          Store             @relation(fields: [storeId], references: [id])
  items          TransactionItem[]
  shiftId        String
  shift          Shift             @relation(fields: [shiftId], references: [id])
  promoId        String?           // tetap ada — menyimpan promo utama yang dipakai
  promo          Promo?            @relation(fields: [promoId], references: [id])
}

model Shift {
  id                 String        @id @default(uuid())
  opening_cash       Float
  closing_cash       Float?
  total_sales        Float         @default(0)
  total_transactions Int           @default(0)
  status             String        // OPEN | CLOSED
  opened_at          DateTime      @default(now())
  closed_at          DateTime?
  notes              String?
  userId             String
  user               User          @relation(fields: [userId], references: [id])
  cashierName        String        @default("Kasir")
  storeId            String
  store              Store         @relation(fields: [storeId], references: [id])
  transactions       Transaction[]
}

// ============================================================
// MODEL Promo — diperbarui untuk multi-rule
// ============================================================
model Promo {
  id          String      @id @default(uuid())
  storeId     String
  name        String

  // ── Field baru ──────────────────────────────────────────
  tag         String?     // label warna: "red"|"orange"|"blue"|"green"|"purple"
  priority    Int         @default(1)    // urutan evaluasi; lebih kecil = lebih dulu
  stackable   Boolean     @default(false) // bisa digabung dengan promo lain?
  maxUsage    Int?        // null = tidak terbatas
  usageCount  Int         @default(0)    // counter pemakaian
  // ────────────────────────────────────────────────────────

  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  store        Store         @relation(fields: [storeId], references: [id])
  rules        PromoRule[]   // ← aturan diskon (ganti field lama yang flat)
  transactions Transaction[]

  @@index([storeId])
  @@index([priority])
}

// ============================================================
// MODEL BARU: PromoRule — 1 promo bisa punya banyak aturan
// ============================================================
model PromoRule {
  id            String  @id @default(uuid())
  promoId       String
  order         Int     @default(0) // urutan rule dalam promo

  // Tipe aturan: PRODUCT | HAPPY_HOUR | MIN_TRANSACTION
  type          String
  // Tipe diskon: PERCENT | NOMINAL
  discountType  String
  // Nilai diskon
  discountValue Int

  // Untuk tipe PRODUCT
  productId     String?
  product       Product? @relation(fields: [productId], references: [id])

  // Untuk tipe HAPPY_HOUR — format "HH:mm"
  startTime     String?
  endTime       String?

  // Untuk tipe MIN_TRANSACTION
  minTransaction Int?

  promo         Promo   @relation(fields: [promoId], references: [id], onDelete: Cascade)

  @@index([promoId])
  @@index([order])
}
