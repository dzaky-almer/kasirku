generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  shifts       Shift[]
  stores       Store[]
  subscription Subscription?
}

model Store {
  id           String        @id @default(uuid())
  name         String
  type         String
  userId       String
  createdAt    DateTime      @default(now())
  products     Product[]
  promos       Promo[]
  shifts       Shift[]
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId])
}

model Product {
  id               String            @id @default(uuid())
  name             String
  barcode          String?
  sku              String?
  price            Int
  costPrice        Int?
  stock            Int               @default(0)
  minStock         Int               @default(5)
  unit             String            @default("pcs")
  category         String?
  imageUrl         String?
  storeId          String
  label            String?
  store            Store             @relation(fields: [storeId], references: [id])
  promoRules       PromoRule[]
  transactionItems TransactionItem[]

  @@index([storeId])
  @@index([storeId, name])
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  productId     String
  qty           Int
  price         Int
  product       Product     @relation(fields: [productId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
  @@index([productId])
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique
  plan      String
  startDate DateTime
  expiredAt DateTime
  status    String
  user      User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id             String            @id @default(uuid())
  storeId        String
  total          Int
  paymentMethod  String            @default("cash")
  createdAt      DateTime          @default(now())
  shiftId        String
  discountAmount Int               @default(0)
  promoId        String?
  promo          Promo?            @relation(fields: [promoId], references: [id])
  shift          Shift             @relation(fields: [shiftId], references: [id])
  store          Store             @relation(fields: [storeId], references: [id])
  items          TransactionItem[]

  @@index([storeId, createdAt])
  @@index([shiftId])
  @@index([promoId])
}

model Shift {
  id                 String        @id @default(uuid())
  opening_cash       Float
  closing_cash       Float?
  total_sales        Float         @default(0)
  total_transactions Int           @default(0)
  status             String
  opened_at          DateTime      @default(now())
  closed_at          DateTime?
  notes              String?
  userId             String
  storeId            String
  cashierName        String        @default("Kasir")
  store              Store         @relation(fields: [storeId], references: [id])
  user               User          @relation(fields: [userId], references: [id])
  transactions       Transaction[]

  @@index([storeId, status])
  @@index([userId, status])
  @@index([storeId, opened_at])
}

model Promo {
  id           String        @id @default(uuid())
  storeId      String
  name         String
  tag          String?
  priority     Int           @default(1)
  stackable    Boolean       @default(false)
  maxUsage     Int?
  usageCount   Int           @default(0)
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  store        Store         @relation(fields: [storeId], references: [id])
  rules        PromoRule[]
  transactions Transaction[]

  @@index([storeId])
  @@index([priority])
}

model PromoRule {
  id             String   @id @default(uuid())
  promoId        String
  order          Int      @default(0)
  type           String
  discountType   String
  discountValue  Int
  productId      String?
  startTime      String?
  endTime        String?
  minTransaction Int?
  product        Product? @relation(fields: [productId], references: [id])
  promo          Promo    @relation(fields: [promoId], references: [id], onDelete: Cascade)

  @@index([promoId])
  @@index([order])
}