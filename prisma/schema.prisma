generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  name         String?
  phone        String?
  createdAt    DateTime      @default(now())
  stores       Store[]
  shifts       Shift[]
  subscription Subscription?
  usedReferralCodes ReferralCode[] @relation("ReferralCodeUsedBy")
}

model Store {
  id           String        @id @default(uuid())
  name         String
  slug         String?       @unique
  type         String
  userId       String
  bookingGraceMinutes Int    @default(30)
  bookingOpenTime String     @default("09:00")
  bookingCloseTime String    @default("21:00")
  bookingSlotMinutes Int     @default(30)
  address      String?
  waNumber     String?
  midtransServerKey String?
  midtransClientKey String?
  isDemo       Boolean       @default(false)
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id])
  products     Product[]
  suppliers    Supplier[]
  stockMovements StockMovement[]
  shifts       Shift[]
  transactions Transaction[]
  promos       Promo[]
  demoSessions DemoSession[]
  bookingResources BookingResource[]
  bookings     Booking[]
}

model Product {
  id               String            @id @default(uuid())
  name             String
  barcode          String?
  sku              String?
  price            Int
  costPrice        Int?
  stock            Int               @default(0)
  minStock         Int               @default(5)
  unit             String            @default("pcs")
  category         String?
  imageUrl         String?
  label            String?
  supplierId       String?
  bookingEnabled   Boolean           @default(false)
  bookingDurationMin Int?
  storeId          String
  store            Store             @relation(fields: [storeId], references: [id])
  supplier         Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  stockMovements   StockMovement[]
  transactionItems TransactionItem[]
  bookingItems     BookingItem[]
  promoRules       PromoRule[]       // ← ganti dari promos Promo[] ke PromoRule[]
}

model Supplier {
  id             String          @id @default(uuid())
  storeId        String
  name           String
  phone          String?
  email          String?
  address        String?
  notes          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products       Product[]
  stockMovements StockMovement[]

  @@index([storeId, isActive])
}

model StockMovement {
  id            String    @id @default(uuid())
  storeId       String
  productId     String
  supplierId    String?
  type          String
  reason        String
  qtyChange     Int
  previousStock Int
  newStock      Int
  note          String?
  referenceType String?
  referenceId   String?
  createdById   String?
  createdAt     DateTime  @default(now())
  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier      Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([productId, createdAt])
  @@index([supplierId])
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  productId     String
  qty           Int
  price         Int
  note          String?
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique
  plan      String
  tier      String   @default("monthly")
  startDate DateTime
  expiredAt DateTime
  status    String
  user      User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id             String            @id @default(uuid())
  storeId        String
  total          Int
  discountAmount Int               @default(0)
  paymentMethod  String            @default("cash")
  status         String            @default("COMPLETED")
  voidReason     String?
  refundReason   String?
  voidedAt       DateTime?
  refundedAt     DateTime?
  createdAt      DateTime          @default(now())
  store          Store             @relation(fields: [storeId], references: [id])
  items          TransactionItem[]
  shiftId        String
  shift          Shift             @relation(fields: [shiftId], references: [id])
  promoId        String?           // tetap ada — menyimpan promo utama yang dipakai
  promo          Promo?            @relation(fields: [promoId], references: [id])
}

model Shift {
  id                 String        @id @default(uuid())
  opening_cash       Float
  closing_cash       Float?
  total_sales        Float         @default(0)
  total_transactions Int           @default(0)
  status             String        // OPEN | CLOSED
  opened_at          DateTime      @default(now())
  closed_at          DateTime?
  notes              String?
  userId             String
  user               User          @relation(fields: [userId], references: [id])
  cashierName        String        @default("Kasir")
  storeId            String
  store              Store         @relation(fields: [storeId], references: [id])
  transactions       Transaction[]
}

// ============================================================
// MODEL Promo — diperbarui untuk multi-rule
// ============================================================
model Promo {
  id          String      @id @default(uuid())
  storeId     String
  name        String

  // ── Field baru ──────────────────────────────────────────
  tag         String?     // label warna: "red"|"orange"|"blue"|"green"|"purple"
  priority    Int         @default(1)    // urutan evaluasi; lebih kecil = lebih dulu
  stackable   Boolean     @default(false) // bisa digabung dengan promo lain?
  maxUsage    Int?        // null = tidak terbatas
  usageCount  Int         @default(0)    // counter pemakaian
  // ────────────────────────────────────────────────────────

  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  store        Store         @relation(fields: [storeId], references: [id])
  rules        PromoRule[]   // ← aturan diskon (ganti field lama yang flat)
  transactions Transaction[]

  @@index([storeId])
  @@index([priority])
}

// ============================================================
// MODEL BARU: PromoRule — 1 promo bisa punya banyak aturan
// ============================================================
model PromoRule {
  id            String  @id @default(uuid())
  promoId       String
  order         Int     @default(0) // urutan rule dalam promo

  // Tipe aturan: PRODUCT | HAPPY_HOUR | MIN_TRANSACTION
  type          String
  // Tipe diskon: PERCENT | NOMINAL
  discountType  String
  // Nilai diskon
  discountValue Int

  // Untuk tipe PRODUCT
  productId     String?
  product       Product? @relation(fields: [productId], references: [id])

  // Untuk tipe HAPPY_HOUR — format "HH:mm"
  startTime     String?
  endTime       String?

  // Untuk tipe MIN_TRANSACTION
  minTransaction Int?

  promo         Promo   @relation(fields: [promoId], references: [id], onDelete: Cascade)

  @@index([promoId])
  @@index([order])
}

model ReferralCode {
  id           String   @id @default(uuid())
  code         String   @unique
  plan         String
  tier         String   @default("monthly")
  durationDays Int
  expiresAt    DateTime?
  isActive     Boolean  @default(true)
  isUsed       Boolean  @default(false)
  usedAt       DateTime?
  usedByUserId String?
  createdAt    DateTime @default(now())
  usedByUser   User?    @relation("ReferralCodeUsedBy", fields: [usedByUserId], references: [id])

  @@index([isActive, isUsed])
}

model DemoSession {
  id         String   @id @default(uuid())
  sessionKey String   @unique
  storeId    String
  startedAt  DateTime @default(now())
  expiresAt  DateTime
  resetCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model BookingResource {
  id          String   @id @default(uuid())
  storeId     String
  type        String
  name        String
  capacity    Int?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@index([storeId, type, isActive])
}

model Booking {
  id            String           @id @default(uuid())
  storeId       String
  resourceId    String?
  type          String
  source        String           @default("ONLINE")
  status        String           @default("PENDING")
  customerName  String
  customerPhone String
  customerNote  String?
  bookingDate   DateTime
  startTime     String
  endTime       String?
  pax           Int?
  areaLabel     String?
  barberName    String?
  dpAmount      Int              @default(0)
  dpStatus      String           @default("UNPAID")
  paymentOrderId String?         @unique
  paymentStatusRaw String?
  dpPaidAt      DateTime?
  checkInAt     DateTime?
  completedAt   DateTime?
  noShowAt      DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  store         Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  resource      BookingResource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  items         BookingItem[]

  @@index([storeId, bookingDate, status])
  @@index([resourceId, bookingDate, status])
  @@index([paymentOrderId])
}

model BookingItem {
  id          String   @id @default(uuid())
  bookingId   String
  productId   String?
  name        String
  itemType    String   @default("PRODUCT")
  qty         Int      @default(1)
  unitPrice   Int      @default(0)
  durationMin Int?
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([productId])
}
